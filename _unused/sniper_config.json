{
  "system": {
    "name": "Professional Sniper Trading Bot",
    "version": "2.0.0",
    "mode": "production"
  },
  
  "trading": {
    "max_daily_trades": 10,
    "max_open_positions": 3,
    "max_spread": 30,
    "magic_number": 202601,
    "min_confluence_score": 65,
    "min_confidence": 0.60,
    "min_risk_reward": 1.5
  },
  
  "risk": {
    "risk_per_trade": 1.0,
    "max_risk": 2.0,
    "min_risk": 0.5,
    "max_drawdown": 20.0,
    "max_daily_drawdown": 5.0,
    "max_position_size": 10.0,
    "min_position_size": 0.01,
    "max_correlation_exposure": 5.0
  },
  
  "regime_detection": {
    "adx_strong_threshold": 30,
    "adx_weak_threshold": 20,
    "volatility_expansion_threshold": 1.3,
    "volatility_compression_threshold": 0.7
  },
  
  "session_trading": {
    "use_session_filter": true,
    "preferred_sessions": ["LONDON", "NEW_YORK", "LONDON_NY_OVERLAP"],
    "avoid_asian_for_gold": true,
    "avoid_off_hours": true
  },
  
  "reversal_detection": {
    "enabled": true,
    "min_signals_required": 4,
    "min_reversal_confidence": 0.65
  },
  
  "pattern_recognition": {
    "enabled": true,
    "min_pattern_reliability": 0.6,
    "require_context_validation": true,
    "prefer_key_level_patterns": true
  },
  
  "confluence_weights": {
    "multi_timeframe": 25,
    "trend_alignment": 20,
    "momentum": 15,
    "volatility": 10,
    "order_blocks": 10,
    "session": 10,
    "volume": 5,
    "pattern": 5
  },
  
  "timeframes": {
    "entry": "H1",
    "trend": "H4",
    "major_trend": "D1",
    "mtf_analysis": ["M15", "H1", "H4", "D1"]
  },
  
  "indicators": {
    "ema_fast": 8,
    "ema_medium": 21,
    "ema_slow": 50,
    "ema_trend": 200,
    "rsi_period": 14,
    "adx_period": 14,
    "atr_period": 14,
    "stochastic_k": 14,
    "stochastic_d": 3,
    "stochastic_slowing": 3
  },
  
  "stop_loss": {
    "method": "ATR",
    "atr_multiplier": 2.0,
    "min_sl_pips": 20,
    "max_sl_pips": 200
  },
  
  "take_profit": {
    "method": "ATR",
    "atr_multiplier": 3.5,
    "min_rr_ratio": 1.5,
    "use_trailing": true,
    "trailing_start_pips": 100,
    "trailing_step_pips": 50
  },
  
  "precious_metals": {
    "gold_size_multiplier": 0.8,
    "silver_size_multiplier": 0.6,
    "gold_max_spread": 40,
    "silver_max_spread": 50,
    "use_gs_ratio": true,
    "gs_ratio_mean": 80.0,
    "gs_ratio_std": 10.0
  },
  
  "symbols": {
    "forex_pairs": [
      "EURUSD",
      "GBPUSD",
      "USDJPY",
      "AUDUSD",
      "USDCAD",
      "NZDUSD",
      "EURGBP",
      "EURJPY"
    ],
    "metals": [
      "XAUUSD",
      "XAGUSD"
    ]
  },
  
  "news_filter": {
    "enabled": true,
    "avoid_minutes_before": 30,
    "avoid_minutes_after": 30,
    "high_impact_only": true
  },
  
  "logging": {
    "level": "INFO",
    "log_trades": true,
    "log_analysis": true,
    "log_to_file": true,
    "log_file": "logs/sniper_bot.log"
  }
}
